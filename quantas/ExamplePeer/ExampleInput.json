{
  "algorithms": [
    "ExamplePeer/ExamplePeer.cpp",
    "ExamplePeer/ExamplePeer2.cpp",
    "ExamplePeer/ChurnExamplePeer.cpp"
  ],
  "logging_level": "trace",
  "experiments": [
    {
      "id": "example1",
      "threadCount": 1,
      "parameters": {
        "parameter1": 100,
        "parameter2": "world",
        "changePeerType": true
      },
      "distribution": {
        "type": "uniform",
        "maxDelay": 3,
        "maxMsgsRec": 10
      },
      "topology": {
        "type": "complete",
        "initialPeers": 5,
        "initialPeerType": "ExamplePeer"
      },
      "tests": 1,
      "rounds": 5
    },
    {
      "id": "example2",
      "threadCount": 1,
      "parameters": {
        "parameter1": 3.14159,
        "parameter2": "hello",
        "changePeerType": false
      },
      "distribution": {
        "type": "uniform",
        "maxDelay": 1
      },
      "topology": {
        "type": "userList",
        "initialPeers": 3,
        "list": {
          "0": [ 1, 2 ],
          "1": [ 2 ]
        },
        "initialPeerType": "ExamplePeer"
      },
      "tests": 1,
      "rounds": 3
    },
    {
      "id": "example3",
      "threadCount": 1,
      "distribution": {
        "type": "uniform",
        "maxDelay": 3
      },
      "topology": {
        "type": "complete",
        "initialPeers": 3,
        "initialPeerType": "ExamplePeer"
      },
      "tests": 2,
      "rounds": 3
    },
    {
      "id": "example_churn",
      "threadCount": 1,
      "parameters": {
        "parameter1": "membership churn",
        "parameter2": "peer id 2 leaves, peer id 3 joins later",
        "initiallyPresentPeerIds": [0, 1, 2],
        "initiallyAbsentPeerIds": [3],
        "events": [
          { "step": 2, "action": "leave", "peerId": 2 },
          { "step": 5, "action": "join", "peerId": 2 },
          { "step": 6, "action": "join", "peerId": 3 }
        ]
      },
      "distribution": {
        "type": "uniform",
        "maxDelay": 1,
        "maxMsgsRec": 10
      },
      "topology": {
        "type": "complete",
        "initialPeers": 4,
        "initialPeerType": "ChurnExamplePeer"
      },
      "tests": 1,
      "rounds": 8
    }
  ]
}
